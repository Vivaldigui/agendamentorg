rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          "gui.rib.pi@gmail.com"
        ];
    }

    match /vagas_ocupadas/{slotId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /dados_cidadaos/{documentId} {
      allow create: if isAdmin();
      allow get, list, update, delete: if isAdmin();
    }

    match /cpfs_agendados/{documentId} {
      allow create: if isAdmin();
      allow get, list, update, delete: if isAdmin();
    }

    match /bloqueios_agendamento/{cpf} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /cancelamentos_pendentes/{documentId} {
      allow read, write: if false;
    }

    match /logs_admin/{documentId} {
      allow create, get, list: if isAdmin();
      allow update, delete: if false;
    }

    match /rate_limits/{documentId} {
      allow read, write: if false;
    }

    match /configuracoes/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
